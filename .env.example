# --- Public RPC + mint (devnet) ---
RPC_URL=https://api.devnet.solana.com
ASHEM_MINT=
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_ASHEM_MINT=

# --- Liquidity pool (devnet) ---
POOL_ID=
POOL_TESTER_KEYPAIR=/absolute/path/to/pool-tester.json

# --- Faucet dispenser (devnet, zero value) ---
# Dev: path to a keypair file. Prod: set DISPENSER_SECRET_KEY as a JSON array string instead.
DISPENSER_KEYPAIR_PATH=/absolute/path/to/dispenser.json
# DISPENSER_SECRET_KEY=[1,2,3,...]
DISPENSE_SOL_LAMPORTS=20000000
DISPENSE_ASHEM=5000
RATE_LIMIT_HOURS=24

# --- Harvest dispatch (GitHub Actions) ---
# Fine-grained PAT: single repo, "Actions: Read and write" only.
GH_DISPATCH_TOKEN=
GH_REPO=AshandEmber-Sol/-ASHEM
GH_WORKFLOW=endgame.yml
# --- Rate-limit store (Upstash Redis via Vercel Marketplace) ---
# Provisioned by the Vercel "Upstash for Redis" integration, which injects these.
# Optional locally: without them, /api/harvest falls back to a best-effort
# in-memory cooldown (not safe across serverless instances).
KV_REST_API_URL=
KV_REST_API_TOKEN=
